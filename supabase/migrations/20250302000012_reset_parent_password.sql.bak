-- =====================================================
-- Réinitialiser le mot de passe d'un parent
-- À utiliser si un parent ne peut pas se connecter
-- =====================================================

-- Remplacez par l'email du parent concerné
DO $$
DECLARE
  v_parent_email VARCHAR := 'altman25@gmail.com';  -- ← MODIFIER
  v_new_password VARCHAR := 'NovaConnect2025!';  -- ← MODIFIER (nouveau mot de passe)
  v_user_id UUID;
BEGIN
  -- Récupérer l'ID de l'utilisateur
  SELECT id INTO v_user_id
  FROM auth.users
  WHERE email = v_parent_email;

  IF v_user_id IS NULL THEN
    RAISE EXCEPTION 'Utilisateur % non trouvé', v_parent_email;
  END IF;

  -- Mettre à jour le mot de passe en utilisant crypt()
  UPDATE auth.users
  SET encrypted_password = crypt(v_new_password, gen_salt('bf'))
  WHERE id = v_user_id;

  RAISE NOTICE '✅ Mot de passe réinitialisé pour %', v_parent_email;
  RAISE NOTICE '✅ Nouveau mot de passe: %', v_new_password;
  RAISE NOTICE '✅ Vous pouvez maintenant vous connecter avec ce mot de passe';

END $$;

-- Vérifier que l'utilisateur existe
SELECT email, id::text, created_at, email_confirmed_at
FROM auth.users
WHERE email = 'fadiala@gmail.com';  -- ← MODIFIER
