# Variables d'environnement requises pour generate-qr-code Edge Function

# URL Supabase (automatiquement injectée par Supabase)
# SUPABASE_URL=https://mdfzmdddmwpbqmkxomdb.supabase.co

# Anon Key (automatiquement injectée par Supabase) - utilisée pour valider les JWTs
# SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service Role Key (automatiquement injectée par Supabase) - utilisée pour les opérations DB
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Secret pour signer les QR codes (OBLIGATOIRE - à configurer manuellement)
QR_SIGNING_SECRET=your-secure-random-secret-here
