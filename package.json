{
  "name": "novaconnect-monorepo",
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=@novaconnect/web",
    "dev:mobile": "turbo run dev --filter=@novaconnect/mobile",
    "build": "turbo run build",
    "build:web": "turbo run build --filter=@novaconnect/web",
    "build:mobile": "turbo run build --filter=@novaconnect/mobile",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "clean": "turbo run clean && rm -rf node_modules .turbo",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --coverage --maxWorkers=2",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report",
    "db:start": "supabase start",
    "db:stop": "supabase stop",
    "db:reset": "supabase db reset",
    "db:migrate": "supabase db push",
    "db:types": "supabase gen types typescript --local > packages/data/src/types/database.generated.ts",
    "db:seed": "supabase db reset --seed",
    "db:status": "supabase status",
    "db:logs": "supabase logs"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@types/jest": "^30.0.0",
    "jest": "^30.2.0",
    "prettier": "^3.4.2",
    "supabase": "^2.39.3",
    "ts-jest": "^29.4.6",
    "turbo": "^2.7.4"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "@sentry/core": "^10.36.0",
    "@supabase/ssr": "^0.6.1",
    "@supabase/supabase-js": "^2.91.1",
    "@types/pg": "^8.16.0",
    "class-variance-authority": "^0.7.1",
    "dotenv": "^17.2.3",
    "pg": "^8.17.2",
    "use-debounce": "^10.1.0"
  }
}
