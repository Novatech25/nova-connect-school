# ===============================================
# NovaConnect Gateway - Configuration Windows
# ===============================================

# Identifiant de l'école (requis)
SCHOOL_ID=

# Configuration Supabase (requis)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_KEY=your-service-role-key-here

# Base de données locale
DATABASE_PATH=C:\ProgramData\NovaConnect\Gateway\data\gateway.db

# Configuration réseau
PORT=3001
HOST=0.0.0.0

# Intervalle de synchronisation (ms)
SYNC_INTERVAL=30000

# Niveau de log (debug, info, warn, error)
LOG_LEVEL=info

# Chemin des logs
LOG_PATH=C:\ProgramData\NovaConnect\Gateway\logs

# Fichier de licence
LICENSE_FILE=C:\ProgramData\NovaConnect\Gateway\license.json

# Environment
NODE_ENV=production
