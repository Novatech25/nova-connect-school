# ==============================================
# NovaConnect Gateway - Configuration TEST
# Architecture Hybride avec Docker
# ==============================================

# ----------------------------------------------
# Configuration du serveur
# ----------------------------------------------
NODE_ENV=production
PORT=3001
GATEWAY_PORT=3001

# ----------------------------------------------
# Base de données locale (SQLite)
# ----------------------------------------------
DATABASE_PATH=/app/data

# ----------------------------------------------
# Identifiant de l'école POUR TEST
# ----------------------------------------------
SCHOOL_ID=test-school-001

# ----------------------------------------------
# Configuration Supabase Cloud (Sync hybride)
# ----------------------------------------------
# REMPLACEZ PAR VOS VRAIES CLEFS SUPABASE
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_KEY=your-service-role-key-here

# ----------------------------------------------
# Configuration de la licence (optionnel)
# ----------------------------------------------
LICENSE_FILE=./license.json

# ----------------------------------------------
# Synchronisation Hybride
# ----------------------------------------------
# Toutes les 30 secondes par défaut
SYNC_INTERVAL=30000

# ----------------------------------------------
# Logging
# ----------------------------------------------
LOG_LEVEL=info

# ----------------------------------------------
# Monitoring (optionnel)
# ----------------------------------------------
DOZZLE_PORT=8080
