{
  "name": "@novaconnect/gateway",
  "version": "1.0.0",
  "description": "NovaConnect Gateway LAN - Offline service for critical operations",
  "main": "src/server.ts",
  "type": "module",
  "scripts": {
    "dev": "bun --env-file .env --watch src/server.ts",
    "build": "bun build src/server.ts --outdir ./dist --target bun",
    "start": "bun --env-file .env src/server.ts",
    "migrate": "bun scripts/migrate.ts",
    "migrate:list": "bun scripts/list-migrations.ts",
    "migrate:status": "bun scripts/migrate-status.ts",
    "migrate:new": "bun scripts/new-migration.ts",
    "activate": "bun scripts/activate.ts",
    "activate-dev": "bun scripts/activate-dev.ts",
    "test": "bun test"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.39.0",
    "hono": "^3.12.0",
    "jspdf": "^4.0.0",
    "multicast-dns": "^7.2.5",
    "node-machine-id": "^1.1.12",
    "qrcode": "^1.5.4",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/multicast-dns": "^7.2.4",
    "@types/node": "^25.0.9",
    "bun-types": "latest"
  }
}
