# ==============================================
# NovaConnect Gateway - Configuration Production
# ==============================================

# ----------------------------------------------
# Configuration du serveur
# ----------------------------------------------
NODE_ENV=production
PORT=3001
GATEWAY_PORT=3001

# ----------------------------------------------
# Base de données
# ----------------------------------------------
DATABASE_PATH=/app/data

# ----------------------------------------------
# Identifiant de l'école
# ----------------------------------------------
# Optionnel si activation via licence
SCHOOL_ID=

# ----------------------------------------------
# Configuration Supabase Cloud (fallback)
# ----------------------------------------------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# ----------------------------------------------
# Configuration de la licence
# ----------------------------------------------
# Chemin vers le fichier de licence (optionnel)
LICENSE_FILE=./license.json

# ----------------------------------------------
# Synchronisation
# ----------------------------------------------
# Intervalle de synchronisation en millisecondes (30s par défaut)
SYNC_INTERVAL=30000

# ----------------------------------------------
# Logging
# ----------------------------------------------
LOG_LEVEL=info

# ----------------------------------------------
# Monitoring (optionnel)
# ----------------------------------------------
# Port pour l'interface de logs (Dozzle)
DOZZLE_PORT=8080
