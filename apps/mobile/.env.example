# NovaConnect Mobile Environment Variables

# ============================================
# API Configuration
# ============================================
EXPO_PUBLIC_API_URL=https://api.novaconnect.fr

# ============================================
# Supabase Configuration
# ============================================
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# ============================================
# PWA Configuration (Web only)
# ============================================

# Enable PWA features
EXPO_PUBLIC_PWA_ENABLED=true

# Service Worker update check interval (in milliseconds)
EXPO_PUBLIC_SW_UPDATE_INTERVAL=3600000

# Cache version (increment to force cache invalidation)
EXPO_PUBLIC_CACHE_VERSION=1.0.0

# VAPID Public Key for Web Push Notifications
# Generate with: npx web-push generate-vapid-keys
EXPO_PUBLIC_VAPID_PUBLIC_KEY=your_vapid_public_key_here

# ============================================
# Authentication Configuration
# ============================================
EXPO_PUBLIC_AUTH_URL=https://auth.novaconnect.fr

# ============================================
# Analytics Configuration
# ============================================
EXPO_PUBLIC_ANALYTICS_ENABLED=false
EXPO_PUBLIC_GA_TRACKING_ID=your_tracking_id_here

# ============================================
# Feature Flags
# ============================================
EXPO_PUBLIC_FEATURE_OFFLINE_MODE=true
EXPO_PUBLIC_FEATURE_PUSH_NOTIFICATIONS=true
EXPO_PUBLIC_FEATURE_BACKGROUND_SYNC=true

# ============================================
# Development Configuration
# ============================================
EXPO_PUBLIC_DEV_MODE=false
EXPO_PUBLIC_DEBUG_MODE=false
