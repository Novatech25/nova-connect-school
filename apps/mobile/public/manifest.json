  "shortcuts": [
    {
      "name": "Présence",
      "short_name": "Présence",
      "description": "Marquer la présence des élèves",
      "url": "/attendance?source=pwa",
      "icons": [
        {
          "src": "/assets/icons/shortcut-attendance.png",
          "sizes": "96x96"
        }
      ]
    },
    {
      "name": "Notes",
      "short_name": "Notes",
      "description": "Consulter les notes des élèves",
      "url": "/grades?source=pwa",
      "icons": [
        {
          "src": "/assets/icons/shortcut-grades.png",
          "sizes": "96x96"
        }
      ]
    },
    {
      "name": "EDT",
      "short_name": "EDT",
      "description": "Voir l'emploi du temps",
      "url": "/schedule?source=pwa",
      "icons": [
        {
          "src": "/assets/icons/shortcut-schedule.png",
          "sizes": "96x96"
        }
      ]
    },
    {
      "name": "Notifications",
      "short_name": "Notifs",
      "description": "Voir les notifications",
      "url": "/notifications?source=pwa",
      "icons": [
        {
          "src": "/assets/icons/shortcut-notifications.png",
          "sizes": "96x96"
        }
      ]
    }
  ],
  "share_target": {
    "action": "/share?source=pwa",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url",
      "files": [
        {
          "name": "file",
          "accept": ["image/*", ".pdf", ".doc", ".docx", ".xls", ".xlsx"]
        }
      ]
    }
  },
  "protocol_handlers": [
    {
      "protocol": "web+novaconnect",
      "url": "/handler?source=%s"
    }
  ]
}
